# =====================================================
# FILE NÀY LÀ MẪU — COPY THÀNH .env VÀ ĐIỀN GIÁ TRỊ THẬT VÀO
# TUYỆT ĐỐI KHÔNG COMMIT FILE .env LÊN GITHUB!
# =====================================================

# === SUPABASE ===
# Lấy tại: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key>

# === GROQ AI (Llama 3.3 — Miễn phí) ===
# Đăng ký và lấy key miễn phí tại: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL_NAME=llama-3.3-70b-versatile
