# =====================================================
# Repository-wide environment variables
# Copy this file to .env at the repository root.
# Do not create per-folder .env files.
# =====================================================

# Supabase project metadata
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Supabase backend/admin access
# Required for backend demo ingest and alert creation.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public Supabase variables exposed to the Vite frontend
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional LLM provider for backend spike analysis.
# Values: auto, openrouter, openai, gemini, groq, mock.
# auto chooses the first configured key in this order:
# OpenRouter -> OpenAI -> Gemini -> Groq -> mock.
LLM_PROVIDER=auto

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=openrouter/owl-alpha
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AI Quality Intelligence Platform

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Optional Lovable AI integration
LOVABLE_API_KEY=

# Live feedback stream
# Set LIVE_STREAM_ENABLED=true to start streaming automatically on backend startup.
LIVE_STREAM_ENABLED=false
LIVE_STREAM_BATCH_SIZE=150
LIVE_STREAM_INTERVAL_SECONDS=1
LIVE_STREAM_LOOP=true
LIVE_STREAM_RESET_ON_START=false

# Auto ticket generation while live stream is running.
AUTO_TICKET_ENABLED=true
AUTO_TICKET_EVERY_BATCHES=10
AUTO_TICKET_MAX_FEEDBACK=1000
AUTO_TICKET_MAX_SPIKES=1
AUTO_TICKET_WORKFLOW_ENABLED=true
AUTO_TICKET_IN_PROGRESS_AFTER_SECONDS=10
AUTO_TICKET_RESOLVED_AFTER_SECONDS=30

# Backend API used by the UI server functions.
BACKEND_API_URL=http://127.0.0.1:8000
VITE_BACKEND_API_URL=http://127.0.0.1:8000
